                return
            
            # Pick the first available event ID
            valid_event_id = events_data[0]['id']
            valid_event_name = events_data[0]['name']
            print(f"✅ [SDK] Found Event '{valid_event_name}' with ID: {valid_event_id}")
        else:
            print("❌ [SDK] Failed to fetch events from daemon.")
            return
            
    # 2. Provision Persona using dynamic event ID and auto-provisioned topics
