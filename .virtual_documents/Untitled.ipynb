        disconnect_response = await sdk.mcp_management.post_api_v1_mcp_disconnect_async()
        print(f"✅ [SDK] Disconnect Response: {disconnect_response}")

# Execute the test
await run_test()

# 10. STOP the server to prevent infinite pings and free the port!
mcp_host.stop()
print("Done!")


