        if response.status_code == 200:
            tools_data = response.json().get('tools', [])
            if not tools_data:
                print("❌ [SDK] You have no tools in your database! Please create a Tool in the Ajayji GUI first.")
                return
            
            # Pick the first available tool ID
            valid_tool_id = tools_data[0]['id']
            valid_tool_name = tools_data[0]['name']
            print(f"✅ [SDK] Found Tool '{valid_tool_name}' with ID: {valid_tool_id}")
        else:
            print("❌ [SDK] Failed to fetch tools from daemon.")
            return

    # 2. Provision Persona using the dynamically fetched Tool ID
