import asyncio
from ajayji import SDK
from ajayji.mcp_host import JupyterMCPHost

# 1. Initialize our MCP Host with port=0 for automatic free port discovery
mcp_host = JupyterMCPHost(name="NotebookServer", port=0)

# 2. Define custom Python functions and register them as MCP tools
@mcp_host.tool(name="calculate_complex_math", description="Multiplies a number by 42")
def calculate_complex_math(number: int) -> int:
    print(f"🐍 [Jupyter] Executing native python function with input: {number}")
    return number * 42

@mcp_host.tool(name="add_ten", description="Adds 10 to a number")
def add_ten(number: int) -> int:
    print(f"🐍 [Jupyter] Executing add_ten with input: {number}")
    return number + 10

# 3. Start the FastMCP Server in the background
mcp_host.start()

async def run_test():
    # 4. Initialize the Ajayji SDK
    sdk = SDK()
    
    agent_id = "test_mcp_stateful_agent"
    
    # 5. Provision the Persona using the SDK
    print(f"📡 [SDK] Provisioning Persona...")
    provision_response = await sdk.persona_orchestration.create_persona_async(
        agent_id=agent_id,
        agent_name="Stateful MCP Demo Agent",
        model="gemma-3-1b-it-Q5_K_M.gguf", 
        # Note: We omit mcp_servers here because we want to connect statefully!
        system_prompt="You have access to tools called 'calculate_complex_math' and 'add_ten'. You must use them when asked to perform math."
    )
    print(f"✅ [SDK] Provision Response: {provision_response}")

    # 6. EXPLICITLY CONNECT to the MCP Server
    # This establishes the SSE connection and does the handshake once.
    print(f"🔗 [SDK] Connecting explicitly to MCP server at {mcp_host.sse_uri}...")
    connect_response = await sdk.mcp_management.connect_async(
        request_body={
            "mcp_servers": [mcp_host.sse_uri]
        }
    )
    print(f"✅ [SDK] Connect Response: {connect_response}")

    try:
        # 7. First Invocation (Should be fast, no handshake needed)
        print("🤖 [SDK] Invocation 1: Calling complex math...")
        invoke_response1 = await sdk.persona_orchestration.invoke_persona_async(
            id=agent_id,
            request_body={
                "query": "Please use the calculate_complex_math tool on the number 10 and tell me the result."
            },
            timeout_ms=60000 
        )
        print(f"🎉 [SDK] Response 1: {invoke_response1}")

        # 8. Second Invocation (Reuses the existing connection)
        print("🤖 [SDK] Invocation 2: Calling add ten...")
        invoke_response2 = await sdk.persona_orchestration.invoke_persona_async(
            id=agent_id,
            request_body={
                "query": "Now use the add_ten tool on the number 5 and tell me the result."
            },
            timeout_ms=60000 
        )
        print(f"🎉 [SDK] Response 2: {invoke_response2}")
        
    finally:
        # 9. EXPLICITLY DISCONNECT
        print("🔌 [SDK] Disconnecting from MCP Server...")
        disconnect_response = await sdk.mcp_management.disconnect_async()
        print(f"✅ [SDK] Disconnect Response: {disconnect_response}")

# Execute the test
await run_test()

# 10. STOP the server to prevent infinite pings and free the port!
mcp_host.stop()
print("Done!")





